<html>

<head>
    <title>Sistema Escolar</title>

    <style>
        body {
            margin: 0;
            font-family: Arial, Helvetica, sans-serif;
            background: linear-gradient(120deg, #6a0dad, #b784f7);
        }

        .menu {
            background: #4b0082;
            padding: 15px;
            display: flex;
            justify-content: center;
            gap: 25px;
            color: white;
            font-weight: bold;
        }

        .menu span {
            cursor: pointer;
            padding: 6px 12px;
            border-radius: 8px;
        }

        .menu span:hover {
            background: rgba(255,255,255,0.2);
        }

        .titulo {
            text-align: center;
            color: white;
            margin-top: 20px;
        }

        .pagina {
            display: none;
            max-width: 550px;
            margin: 30px auto;
            padding: 25px;
            background: white;
            border-radius: 15px;
            box-shadow: 0 10px 25px rgba(0,0,0,0.3);
        }

        .pagina-ativa {
            display: block;
        }

        .grupo {
            margin-bottom: 15px;
        }

        .grupo label {
            font-weight: bold;
            display: block;
            margin-bottom: 5px;
        }

        input {
            width: 100%;
            padding: 10px;
            border-radius: 8px;
            border: 1px solid #ccc;
        }

        input:focus {
            outline: none;
            border: 1px solid #6a0dad;
            box-shadow: 0 0 6px #b784f7;
        }

        .cadastrar {
            margin-top: 20px;
            padding: 12px;
            width: 100%;
            border: none;
            background: #6a0dad;
            color: white;
            border-radius: 10px;
            font-size: 16px;
            cursor: pointer;
        }

        .cadastrar:hover {
            background: #4b0082;
        }

        #dashboard {
            display: flex;
            justify-content: center;
            gap: 20px;
            flex-wrap: wrap;
        }

        .card {
            background: white;
            width: 220px;
            padding: 20px;
            border-radius: 15px;
            text-align: center;
            box-shadow: 0 6px 15px rgba(0,0,0,0.2);
        }
        .card:hover{
            transform: translateY(-5px);
            box-shadow: 0 8px 16px rgba(0,0,0,0.2);
            background-color: rgb(239, 221, 252);

        }

        .card p {
            font-size: 28px;
            font-weight: bold;
            color: #6a0dad;
        }

        .resultado {
            max-width: 500px;
            margin: 20px auto;
            background: #4b0082;
            color: white;
            padding: 20px;
            border-radius: 15px;
            display: none;
        }
    </style>

</head>

<body>

    <div class="menu">
        <span onclick="navegar('dashboard')">🏠 Início</span>
        <span onclick="navegar('alunos')">🎓 Alunos</span>
        <span onclick="navegar('professores')">👨‍🏫 Professores</span>
        <span onclick="navegar('funcionarios')">🧑‍💼 Funcionários</span>
    </div>

    <div class="titulo">
        <h1>📚 Sistema Escolar</h1>
    </div>

    <!-- DASHBOARD -->
    <div id="dashboard" class="pagina pagina-ativa">
        <div class="card">
            <h3>🎓 Alunos</h3>
            <p>0</p>
        </div>

        <div class="card">
            <h3>👨‍🏫 Professores</h3>
            <p>0</p>
        </div>

        <div class="card">
            <h3>🧑‍💼 Funcionários</h3>
            <p>0</p>
        </div>
    </div>

    <!-- ALUNOS -->
    <div id="alunos" class="pagina">

        <h2>🎓 Cadastro de Aluno</h2>

        <div class="grupo">
            <label>Nome</label>
            <input type="text" id="nome">
        </div>

        <div class="grupo">
            <label>CPF</label>
            <input type="text" id="cpf">
        </div>

        <div class="grupo">
            <label>Data de Nascimento</label>
            <input type="date" id="dataNasc">
        </div>

        <div class="grupo">
            <label>Idade</label>
            <input type="number" id="idade">
        </div>

        <button class="cadastrar" onclick="mostrarDados()">Cadastrar</button>
    </div>

    <!-- PROFESSORES -->
    <div id="professores" class="pagina">

        <h2>👨‍🏫 Cadastro de Professor</h2>

        <div class="grupo">
            <label>Nome</label>
            <input type="text">
        </div>

        <div class="grupo">
            <label>CPF</label>
            <input type="text">
        </div>

        <div class="grupo">
            <label>Data de Nascimento</label>
            <input type="date">
        </div>

        <div class="grupo">
            <label>Telefone</label>
            <input type="text">
        </div>

        <button class="cadastrar" onclick="mostrarDados()">Cadastrar</button>
    </div>

    <!-- FUNCIONÁRIOS -->
    <div id="funcionarios" class="pagina">

        <h2>🧑‍💼 Cadastro de Funcionário</h2>

        <div class="grupo">
            <label>Nome</label>
            <input type="text">
        </div>

        <div class="grupo">
            <label>CPF</label>
            <input type="text">
        </div>

        <div class="grupo">
            <label>Data de Nascimento</label>
            <input type="date">
        </div>

        <div class="grupo">
            <label>Telefone</label>
            <input type="text">
        </div>

        <button class="cadastrar" onclick="mostrarDados()">Cadastrar</button>
    </div>

    <div id="resultado" class="resultado"></div>

    <script>
        function navegar(pagina) {

            let paginas = document.getElementsByClassName("pagina");

            for (let i = 0; i < paginas.length; i++) {
                paginas[i].classList.remove("pagina-ativa");
            }

            document.getElementById(pagina).classList.add("pagina-ativa");
        }

        function mostrarDados() {

            const abaAtiva = document.querySelector('.pagina-ativa').id;

            let atual = parseInt(localStorage.getItem('cont_' + abaAtiva)) || 0;
            localStorage.setItem('cont_' + abaAtiva, atual + 1);

            document.getElementById("resultado").style.display = "block";
            document.getElementById("resultado").innerHTML =
                "<h2>✅ Cadastro realizado com sucesso!</h2>";

            atualizarDashboard();
        }

        function atualizarDashboard() {
            const alunos = localStorage.getItem('cont_alunos') || 0;
            const profs = localStorage.getItem('cont_professores') || 0;
            const funcs = localStorage.getItem('cont_funcionarios') || 0;

            const cards = document.querySelectorAll("#dashboard .card p");

            cards[0].innerText = alunos;
            cards[1].innerText = profs;
            cards[2].innerText = funcs;
        }

        atualizarDashboard();
    </script>

</body>

</html>
