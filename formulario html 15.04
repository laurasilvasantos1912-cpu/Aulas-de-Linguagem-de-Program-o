<html>

<head>
    <title>Sistema Escolar</title>

    <style>
        body {
            background: linear-gradient(120deg, #d9b3ff, #7a3db8);
            font-family: Arial, Helvetica, sans-serif;
        }

        .titulo {
            text-align: center;
            margin-top: 40px;
            color: black;
            text-shadow: 1px 1px 3px white;
        }

        .pagina {
            background-color: rgb(222, 178, 233);
            width: 400px;
            padding: 20px;
            border-radius: 6px;
            border: 2px steelblue;
            margin: auto;
            margin-top: 50px;
            display: none;
        }

        .pagina-ativa {
            display: block;
        }





        label {
            font-weight: bold;
        }

        input,
        select {
            width: 100%;
            padding: 7px;
            border-radius: 6px;
            border: none;
            margin-top: 3px;
        }

        input:focus,
        select:focus {
            outline: none;
            box-shadow: 0px 0px 8px #d9b3ff;
        }

        hr {
            border: 1px solid #d9b3ff;
        }

        .cadastrar {
            cursor: pointer;
            margin: auto;
            display: block;
            padding: 10px;
            width: 160px;
            background-color: black;
            color: white;
            border: none;
            border-radius: 6px;
            font-size: 16px;
            transition: 0.3s;
        }

        .cadastrar:hover {
            background-color: #d9b3ff;
            color: black;
            transform: scale(1.05);
        }

        .resultado {
            width: 600px;
            margin: 20px auto;
            background-color: #5a189a;
            color: white;
            padding: 15px;
            border-radius: 12px;
            box-shadow: 0px 0px 1px black;
        }

        .menu {
            background-color: rgb(226, 181, 228);
            color: #f5f5f5;
            padding: 15px;
            display: flex;
            align-items: center;
        }

        .menu-esquerda,
        .menu-centro,
        .menu-direita {
            flex: 1;

        }

        .menu-centro {
            display: flex;
            justify-content: center;
            gap: 10px;
        }

        .menu-direita {
            display: flex;
            justify-content: flex-end;
            gap: 10px;



        }

        .menu span {
            cursor: pointer;
        }

        .card {
            background-color: #f5f5f5;
            padding: 20px;
            border-radius: 4px;
            text-decoration: center;
            flex: 1;
            box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
            margin-top: 20px;
            margin-bottom: 10px;
            

        }

        #dashboard {
            box-sizing: border-box;
            flex-direction: column;
            flex-wrap: wrap;
            justify-content: center;
            gap: 20px;
        }
    </style>

</head>

<body>

    <div class="menu">

        <div class="menu-esquerda"></div>
        <div class="menu-centro">
            <span onclick="navegar ('dashboard')">Inicio</span>
            <span onclick="navegar('alunos')">Alunos</span>
            <span onclick="navegar('professores')">Professores</span>
            <span onclick="navegar('funcionarios')">Funcionarios</span>
        </div>
            <div class="menu-direita">
        <span>Login</span>

    </div>

    </div> 








    <div class="titulo">
        <h1>EEB Dom Jaime de Barros Camara</h1>
        <p>Preencha o formulario abaixo para cadastrar um novo aluno</p>
    </div>

    <!---------------------------------------------------------DASHBOARD------------------------------------------------------------------->
    <div id="dashboard" class="pagina pagina-ativa">

        <div class="card">
            <h1>Alunos Cadastrados</h1>
            <p>0</p>
            
        </div>
        <div class="card">
                <h2>Docentes lecionando na unidade</h2>
                <p>0</p>
                

                
            </div>
        <div class="card">
                    <h3>Funcionarios</h3>
                    <p>0</p>


                </div>
    </div>










        <!---------------------------------------------------------ALUNOS------------------------------------------------------------------->
        <div id="alunos" class="pagina">

            <div class="titulo">
                <h1>EEB Dom Jaime de Barros Camara</h1>

                <p>Preencha o formulário abaixo para cadastrar um novo aluno</p>



            </div>
            <form class="form">



                <label for="Nome">Nome:</label>
                <input type="text" id="nome"><br><br>

                <label>Idade:</label>
                <input type="number" id="idade"><br><br>

                <label>Data de nascimento:</label>
                <input type="date" id="dataNasc"><br><br>

                <label>CPF do aluno:</label>
                <input type="text" id="cpf"><br><br>

                <label>Email:</label>
                <input type="text" id="email"><br><br>


                <label>Série:</label>
                <select id="serie">
                    <option>1º ano</option>
                    <option>2º ano</option>
                    <option>3º ano</option>
                    <option>4º ano</option>
                    <option>5º ano</option>
                    <option>6º ano</option>
                    <option>7º ano</option>
                    <option>8º ano</option>
                    <option>9º ano</option>
                </select><br><br>


                <label>Turno:</label>
                <select id="turno">
                    <option>Manhã</option>
                    <option>Tarde</option>
                    <option>Noite</option>
                </select><br><br>



                <label>Nome do Pai:</label>
                <input type="text" id="nomePai"><br><br>

                




                <label>Nome da Mãe:</label>
                <input type="text" id="nomeMae"><br><br>

                


                <button type="button" class="cadastrar" onclick="mostrarDados()">Cadastrar</button>
                </button type="reset"
                    onclick="document.getElementById('resultado').style.display='none'">Limpar</button>

            </form>

        </div>
        <!----------------------------------------PROFESSORES------------------------------------->

        <div id="professores" class="pagina">

            <div class="titulo">
                <h1>EEB Dom Jaime de Barros Camara</h1>

                <p>Preencha o formulário abaixo para cadastrar um novo professor</p>



            </div>
            <form class="form">





                <label for="Nome">Nome:</label>
                <input type="text" id="nome"><br><br>

                <label>Idade:</label>
                <input type="number" id="idade"><br><br>

                <label>Data de nascimento:</label>
                <input type="date" id="dataNasc"><br><br>

                <label>CPF:</label>
                <input type="text" id="cpf"><br><br>

                <label>Email:</label>
                <input type="text" id="email"><br><br>




                <label>Turno:</label>
                <select id="turno">
                    <option>Manhã</option>
                    <option>Tarde</option>
                    <option>Noite</option>
                </select><br><br>






                <button type="button" class="cadastrar" onclick="mostrarDados()">Cadastrar</button>
                </button type="reset"
                    onclick="document.getElementById('resultado').style.display='none'">Limpar</button>

            </form>

        </div>

        <!--------------------------------------Funcionarios------------------------------------------------>
        <div id="funcionarios" class="pagina">

            <div class="titulo">
                <h1>EEB Dom Jaime de Barros Camara</h1>

                <p>Preencha o formulário abaixo para cadastrar um novo funcionario</p>



            </div>
            <form class="form">




                <label for="Nome">Nome:</label>
                <input type="text" id="nome"><br><br>

                <label>Idade:</label>
                <input type="number" id="idade"><br><br>

                <label>Data de nascimento:</label>
                <input type="date" id="dataNasc"><br><br>

                <label>CPF:</label>
                <input type="text" id="cpf"><br><br>

                <label>Email:</label>
                <input type="text" id="email"><br><br>




                <label>Turno:</label>
                <select id="turno">
                    <option>Manhã</option>
                    <option>Tarde</option>
                    <option>Noite</option>
                </select><br><br>




                <button type="button" class="cadastrar" onclick="mostrarDados()">Cadastrar</button>
                </button type="reset"
                    onclick="document.getElementById('resultado').style.display='none'">Limpar</button>

            </form>

        </div>











        <div id="resultado" class="resultado"></div>

        <script>
            function navegar(pagina) {

                let paginas = document.getElementsByClassName("pagina");

                for (let i = 0; i < paginas.length; i++) {
                    paginas[i].classList.remove("pagina-ativa");
                }

                document.getElementById(pagina).classList.add("pagina-ativa");








            }

            function mostrarDados() {

                let nome = document.getElementById("nome").value;
                let idade = document.getElementById("idade").value;
                let dataNasc = document.getElementById("dataNasc").value;
                let cpf = document.getElementById("cpf").value;
                let email = document.getElementById("email").value;

                let serie = document.getElementById("serie").value;
                let turno = document.getElementById("turno").value;

                let nomePai = document.getElementById("nomePai").value;
                let cpfPai = document.getElementById("cpfPai").value;

                let nomeMae = document.getElementById("nomeMae").value;
                let cpfMae = document.getElementById("cpfMae").value;

                const abaAtiva = document.querySelector('.pagina-ativa').id;
                let atual = parseInt(localStorage.getItem('cont_' + abaAtiva)) || 0;
                localStorage.setItem('cont_' + abaAtiva, atual + 1);


                document.getElementById("resultado").innerHTML =
                    "<h2>Dados Informados:</h2>" +

                    "Aluno: " + nome + "<br>" +
                    "Idade: " + idade + "<br>" +
                    "Nascimento: " + dataNasc + "<br>" +
                    "CPF: " + cpf + "<br>" +
                    "Email: " + email + "<br>" +
                    "Série: " + serie + "<br>" +
                    "Turno: " + turno + "<br><br>" +

                    "<b>Pai</b><br>" +
                    "Nome: " + nomePai + "<br>" +
                

                    "<b>Mãe</b><br>" +
                    "Nome: " + nomeMae + "<br>" +
                    

                dashboard();



                function dashboard() {
                    const qtdAlunos = localStorage.getItem('cont_alunos') || 0;
                    const qtdProfs = localStorage.getItem('cont_professores') || 0;
                    const qtdFuncs = localStorage.getItem('cont_funcionarios') || 0;

                    const cards = document.querySelectorAll("#dashboard .card p");

                    cards[0].innerText = qtdAlunos;
                    cards[1].innerText = qtdProfs;
                    cards[2].innerText = qtdFuncs;

                }



            }

        </script>

</body>

</html>
